<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="boundary.FormGestionePrenotazioni">
  <grid id="a001" binding="pannelloGestionePrenotazioni" layout-manager="GridLayoutManager" row-count="2" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="12" vgap="12">
    <margin top="20" left="25" bottom="20" right="25"/>
    <constraints>
      <xy x="20" y="20" width="620" height="380"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="a002" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="18" style="1"/>
          <horizontalAlignment value="0"/>
          <text value="Le mie prenotazioni"/>
        </properties>
      </component>
      <scrollpane id="a003">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="220" height="300"/>
          </grid>
        </constraints>
        <properties/>
        <border type="etched"/>
        <children>
          <component id="a004" class="javax.swing.JList" binding="listaPrenotazioni">
            <constraints/>
            <properties>
              <selectionMode value="0"/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <grid id="a005" layout-manager="GridLayoutManager" row-count="9" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="8">
        <margin top="10" left="12" bottom="10" right="12"/>
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="330" height="300"/>
          </grid>
        </constraints>
        <properties/>
        <border type="etched"/>
        <children>
          <component id="a006" class="javax.swing.JLabel" binding="etichettaData">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Seleziona una prenotazione"/>
            </properties>
          </component>
          <component id="a007" class="javax.swing.JLabel" binding="etichettaPostazione">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Postazione: -"/>
            </properties>
          </component>
          <component id="a008" class="javax.swing.JLabel" binding="etichettaServizi">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Servizi: -"/>
            </properties>
          </component>
          <component id="a009" class="javax.swing.JLabel" binding="etichettaStato">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Stato: -"/>
            </properties>
          </component>
          <component id="a010" class="javax.swing.JLabel" binding="etichettaPrezzo">
            <constraints>
              <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Totale: -"/>
            </properties>
          </component>
          <vspacer id="a011">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
            </constraints>
          </vspacer>
          <component id="a014" class="javax.swing.JLabel" binding="etichettaAvviso">
            <constraints>
              <grid row="6" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <text value=" "/>
            </properties>
          </component>
          <component id="a012" class="javax.swing.JButton" binding="bottoneAnnulla">
            <constraints>
              <grid row="7" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="220" height="34"/>
              </grid>
            </constraints>
            <properties>
              <text value="Annulla prenotazione"/>
            </properties>
          </component>
          <component id="a013" class="javax.swing.JButton" binding="bottoneChiudi">
            <constraints>
              <grid row="8" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="220" height="34"/>
              </grid>
            </constraints>
            <properties>
              <text value="Chiudi"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
